# Production baseline (fail-closed)

WRITE_REQUIRE_SIGNATURE=1
WRITE_SIG_TYPE=ed25519                         # ed25519|ecdsa|hmac
WRITE_SIG_PUBLIC=/etc/ao/keys/write-ed25519.pub # required for ed25519/ecdsa
# WRITE_SIG_SECRET=                             # required if WRITE_SIG_TYPE=hmac
WRITE_REQUIRE_NONCE=1
WRITE_ALLOW_ANON=0
WRITE_NONCE_TTL_SECONDS=600
WRITE_NONCE_MAX=1000
OUTBOX_HMAC_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# Optional JWT gate (HS256); set REQUIRE=1 to fail-closed. Secrets must be injected at deploy time.
WRITE_REQUIRE_JWT=0
# WRITE_JWT_HS_SECRET=__SET_JWT_HS_SECRET__
WRITE_WAL_PATH=/var/lib/ao/write-wal.ndjson
WRITE_OUTBOX_PATH=/var/lib/ao/write-outbox.json
WRITE_STATE_DIR=/var/lib/ao/write-state
AO_QUEUE_PATH=/var/lib/ao/outbox-queue.ndjson
AO_QUEUE_LOG_PATH=/var/log/ao/queue-log.ndjson
AO_QUEUE_MAX_RETRIES=5
OUTBOX_RETRY_LIMIT=5
OUTBOX_BACKOFF_MS=500
STRIPE_WEBHOOK_SECRET=__SET_STRIPE_WEBHOOK_SECRET__  # 32-byte signing secret from Stripe dashboard
PAYPAL_WEBHOOK_STRICT=1                             # require PayPal signature header; set 0 to allow remote verify fallback
WRITE_WEBHOOK_REPLAY_WINDOW=600                     # replay/dedupe window for PSP webhooks (seconds)
WRITE_WEBHOOK_SEEN_TTL=600                          # TTL for seen cache entries (seconds)
#WRITE_WEBHOOK_SEEN_MAX=5000                        # optional cap on seen cache (size in entries)
WRITE_WEBHOOK_RETRY_MAX=5
WRITE_WEBHOOK_RETRY_BASE_SECONDS=30
#WRITE_WEBHOOK_RETRY_MAX_QUEUE=2000                 # optional cap on retry queue depth before sending to DLQ
AO_BRIDGE_MODE=http
AO_BRIDGE_RETRIES=3
AO_BRIDGE_BACKOFF_MS=200
WRITE_IDEM_PATH=/var/lib/ao/write-idem.json
WRITE_RL_WINDOW_SECONDS=60
WRITE_RL_MAX_REQUESTS=200
WRITE_RL_CALLER_MAX=120
#WRITE_UNIQUE_SUBJECT_MAX_PER_IP=100                # cap on distinct subjects per IP per window (spray guard)
#WRITE_RL_BUCKET_TTL_SECONDS=240
#WRITE_RL_MAX_BUCKETS=4096
METRICS_PROM_PATH=/var/lib/ao/metrics.prom
METRICS_FLUSH_INTERVAL_SEC=10
METRICS_DISABLED=0
AUTH_ALLOW_SHELL_FALLBACK=0
CHECKSUM_INTERVAL_SEC=300
# Record pubkey checksum for rotation: sha256sum /etc/ao/keys/write-ed25519.pub

# Immutable export for WeaveDB/Arweave bundler (append-only NDJSON, PII-scrubbed)
# Used for outbox events, WAL audit hashes, state/idempotency snapshots.
# Leave unset to disable.
# WRITE_OUTBOX_EXPORT_PATH=/var/lib/ao/write-export.ndjson
# Optional hardening / persistence
#WRITE_STRICT_OUTBOX_HMAC=1
#WRITE_OUTBOX_HMAC_MODE=legacy           # switch to legacy HMAC payload if AO still expects it
#OUTBOX_REPLAY_LIMIT=0                   # optional cap when replaying persisted outbox
#OUTBOX_REPLAY_DRY_RUN=0                 # set to 1 to verify HMAC without writing queue
#WRITE_RATE_STORE_PATH=/var/lib/blackcat/write-rate-store.json
#WRITE_NONCE_STORE_PATH=/var/lib/blackcat/write-nonce-store.json
